{
  "openapi": "3.1.0",
  "info": {
    "title": "Project API Reference",
    "description": "API documentation for the S02-26-Equipo-03 project",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "/",
      "description": "Local server"
    }
  ],
  "paths": {
    "/api/health": {
      "get": {
        "summary": "Health Check",
        "description": "Verifica la conectividad con la base de datos y el estado del servidor.",
        "responses": {
          "200": {
            "description": "Health status with database connectivity and timestamp",
            "content": {
              "application/json": {
                "example": {
                  "status": "ok",
                  "database": "connected",
                  "message": "Hello World Backend",
                  "timestamp": "2024-02-17T20:00:00.000Z",
                  "environment": "development"
                }
              }
            }
          }
        }
      }
    },
    "/api/analytics": {
      "get": {
        "summary": "Get Analytics",
        "tags": ["Analytics"],
        "description": "Fetches the latest records from the analytics table. Restricted to authenticated users.",
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Latest analytics records",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string" },
                    "data": { "type": "array", "items": { "type": "object" } },
                    "count": { "type": "integer" }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/api/auth/sign-up/email": {
      "post": {
        "summary": "User Registration",
        "tags": ["Auth"],
        "description": "Register a new user using email and password.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": { "type": "string", "format": "email" },
                  "password": { "type": "string" },
                  "name": { "type": "string" }
                },
                "required": ["email", "password", "name"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "User created successfully"
          }
        }
      }
    },
    "/api/auth/sign-in/email": {
      "post": {
        "summary": "User Login",
        "tags": ["Auth"],
        "description": "Login with email and password.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": { "type": "string", "format": "email" },
                  "password": { "type": "string" }
                },
                "required": ["email", "password"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Logged in successfully"
          }
        }
      }
    },
    "/api/auth/get-session": {
      "get": {
        "summary": "Get Current Session",
        "tags": ["Auth"],
        "description": "Returns the current authenticated user session.",
        "responses": {
          "200": {
            "description": "Session details"
          },
          "401": {
            "description": "Not logged in"
          }
        }
      }
    },
    "/api/auth/sign-out": {
      "post": {
        "summary": "User Logout",
        "tags": ["Auth"],
        "description": "Ends the current session.",
        "responses": {
          "200": {
            "description": "Logged out successfully"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "cookieAuth": {
        "type": "apiKey",
        "in": "cookie",
        "name": "better-auth.session-token",
        "description": "Session token generated by Better Auth"
      }
    }
  }
}
